<Window
    x:Class="gcmloader.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="gcmloader"
    >

    <!-- 
        Main container with a dark background (similar to your app's theme).
        We center everything using the Grid.
    -->
    <Grid Background="#FF1E1E1E">

        <!-- 
            A StackPanel to hold 5 horizontal tiles.
            Orientation="Horizontal" means the elements are laid out left-to-right.
            HorizontalAlignment/VerticalAlignment center the panel on the screen.
            Spacing sets the distance between each child.
        -->
        <StackPanel 
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="40">

            <!-- Tile 1 -->
            <Border 
                x:Name="Tile1"
                Width="150"
                Height="250"
                CornerRadius="20"
                BorderBrush="Transparent"
                BorderThickness="1"
                Margin="10"/>

            <!-- Tile 2 -->
            <Border 
                x:Name="Tile2"
                Width="150"
                Height="250"
                CornerRadius="20"
                BorderBrush="Transparent"
                BorderThickness="1"
                Margin="10"/>

            <!-- Tile 3 -->
            <Border 
                x:Name="Tile3"
                Width="150"
                Height="250"
                CornerRadius="20"
                BorderBrush="Transparent"
                BorderThickness="1"
                Margin="10"/>

            <!-- Tile 4 -->
            <Border 
                x:Name="Tile4"
                Width="150"
                Height="250"
                CornerRadius="20"
                BorderBrush="Transparent"
                BorderThickness="1"
                Margin="10"/>

            <!-- Tile 5 -->
            <Border 
                x:Name="Tile5"
                Width="150"
                Height="250"
                CornerRadius="20"
                BorderBrush="Transparent"
                BorderThickness="1"
                Margin="10"/>

        </StackPanel>
    </Grid>
</Window>
